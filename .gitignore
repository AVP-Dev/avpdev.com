# Файл для хранения секретов и переменных окружения
# САМОЕ ВАЖНОЕ! Никогда не выкладывай этот файл в публичный доступ.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Папки с зависимостями, которые устанавливаются через npm
# Они весят очень много, и каждый разработчик устанавливает их сам.
node_modules/

# Логи и файлы отладки
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Системные файлы операционных систем
.DS_Store
Thumbs.db

# Папки с кэшем и временными файлами редакторов кода
.idea/
.vscode/

# Папки для сборки проекта (если они появятся в будущем)
dist/
build/
.vercel/
.output/

.vercel
