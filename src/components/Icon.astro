---
// src/components/Icon.astro
// Wrapper component that restores original FontAwesome classes
// Allows us to keep the component-based approach while fixing the visual rendering issues.

export interface Props {
  name: string;
  class?: string;
  'aria-hidden'?: boolean | "true" | "false";
  style?: string;
}

const { name, class: className = '', 'aria-hidden': ariaHidden = 'true', style } = Astro.props;

// Determine if it's a brand icon or solid icon
const isBrand = ['fa-github', 'fa-linkedin-in', 'fa-telegram-plane', 'fa-whatsapp', 'fa-react', 'fa-node-js', 'fa-docker', 'fa-html5', 'fa-css3-alt', 'fa-js-square'].includes(name);
const prefix = isBrand ? 'fab' : 'fas';
---

<i class:list={[prefix, name, className]} aria-hidden={ariaHidden} style={style}></i>
