const svgPath = icons[name] ?? '';
const viewBox = name.startsWith('fa-') ? '0 0 16 16' : '0 0 16 16';
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={viewBox}
  fill="currentColor"
  width="1em"
  height="1em"
  class={className}
  aria-hidden={ariaHidden}
  style={style}
  set:html={svgPath}
/>
