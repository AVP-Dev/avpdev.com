---
// src/components/LanguageSwitcher.astro
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const locales = ['ru', 'en'];

// Логика получения пути для другого языка
// Если мы на /ru/about, то pathWithoutLang будет /about
let pathWithoutLang = Astro.url.pathname;
if (pathWithoutLang.startsWith(`/${lang}/`)) {
    pathWithoutLang = pathWithoutLang.replace(`/${lang}/`, '/');
} else if (pathWithoutLang === `/${lang}` || pathWithoutLang === `/${lang}/`) {
    pathWithoutLang = '/';
}
---
<div class="lang-switcher">
    {locales.map((locale, index) => {
        const isActive = locale === lang;
        
        // Мапинг путей для локалей
        let targetPath = pathWithoutLang;
        
        const servicePairs = {
            'razrabotka-saitov': 'website-development',
            'ai-integracii': 'ai-integration',
            'razrabotka-botov-i-parserov': 'bot-and-scraper-development',
            'telegram-mini-apps': 'telegram-mini-apps',
            'saas-mvp': 'saas-mvp'
        };

        const cleanPath = targetPath.endsWith('/') ? targetPath.slice(0, -1) : targetPath;

        if (locale === 'en') {
            // Translating to EN
            let found = false;
            for (const [ruSlug, enSlug] of Object.entries(servicePairs)) {
                if (cleanPath === `/uslugi/${ruSlug}`) {
                    targetPath = `/services/${enSlug}`;
                    found = true;
                    break;
                }
            }
            if (!found && (cleanPath === '/uslugi')) {
                targetPath = '/services';
            }
        } else if (locale === 'ru') {
            // Translating to RU
            let found = false;
            for (const [ruSlug, enSlug] of Object.entries(servicePairs)) {
                if (cleanPath === `/services/${enSlug}`) {
                    targetPath = `/uslugi/${ruSlug}`;
                    found = true;
                    break;
                }
            }
            if (!found && (cleanPath === '/services')) {
                targetPath = '/uslugi';
            }
        }

        const url = `/${locale}${targetPath === '/' ? '' : targetPath}`;
        
        return (
            <>
                {isActive ? (
                    <button class="lang-btn active">{locale.toUpperCase()}</button>
                ) : (
                    <a href={url} class="lang-btn">{locale.toUpperCase()}</a>
                )}
                {index < locales.length - 1 && <span class="lang-separator">|</span>}
            </>
        )
    })}
</div>