---
import BaseLayout from './BaseLayout.astro';
import Cta from '../components/Cta.astro';
import GeoHero from '../components/sections/GeoHero.astro';
import Services from '../components/sections/Services.astro';
import Portfolio from '../components/sections/Portfolio.astro';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  h1: string;
  p: string;
  projects?: any[]; // Pass specific projects for this city
  citySlug?: string;
  cityName?: string;
}

const { title, description, h1, p, projects, citySlug, cityName } = Astro.props;
const lang = getLangFromUrl(Astro.url);

// Dynamic ordering logic to avoid identical DOM structure across all geo-pages
// Even slugs get Service-first, odd slugs get Portfolio-first
const isEven = citySlug ? citySlug.length % 2 === 0 : true;
---
<BaseLayout title={title} description={description} isTranslationKey={false}>
  <Fragment slot="head">
    <slot name="head" />
  </Fragment>

  <GeoHero h1={h1} p={p} />
  
  <div class="geo-sections-wrapper">
    {isEven ? (
      <>
        <Services cityName={cityName} />
        <Portfolio projects={projects} />
      </>
    ) : (
      <>
        <Portfolio projects={projects} />
        <Services cityName={cityName} />
      </>
    )}
    
    <div class="geo-custom-content">
      <slot />
    </div>
  </div>

  <div class="container">
    <Cta />
  </div>
</BaseLayout>

<style>
  .geo-sections-wrapper {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }
</style>