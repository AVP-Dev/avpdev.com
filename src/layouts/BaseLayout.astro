---
import { ClientRouter } from 'astro:transitions';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import type { ui } from '../i18n/ui';
import { locations } from '../data/locations';
import { geoContent } from '../data/geo-content';

// --- ШРИФТЫ (Self-hosted) ---
import '@fontsource-variable/sora';
import '@fontsource-variable/plus-jakarta-sans';
import '@fontsource/jetbrains-mono';

import '../styles/style.css';
import '../styles/case-study.css';
import '../styles/blog.css';

export interface Props {
	title: string;
	description: string;
    ogImage?: string;
    isTranslationKey?: boolean;
    schema?: Record<string, any>;
}

const {
    title,
    description,
    ogImage = '/og-image.webp',
    isTranslationKey = true,
    schema,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const finalTitle = isTranslationKey ? t(title as any) : title;
const finalDescription = isTranslationKey ? t(description as any) : description;

const canonicalURL = new URL(Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`, Astro.site);
const GTAG_ID = import.meta.env.PUBLIC_GTAG_ID;

// SEO: Hreflang Tags Logic
let currentPath = Astro.url.pathname;
if (!currentPath.endsWith('/')) { currentPath += '/'; }

const pathWithoutLocale = currentPath.replace(/^\/(ru|en)\//, '/');
const cleanPath = pathWithoutLocale.endsWith('/') ? pathWithoutLocale.slice(0, -1) : pathWithoutLocale;

const servicePairs = {
    'razrabotka-saitov': 'website-development',
    'ai-integracii': 'ai-integration',
    'razrabotka-botov-i-parserov': 'bot-and-scraper-development',
    'telegram-mini-apps': 'telegram-mini-apps',
    'saas-mvp': 'saas-mvp'
};

let enSlug = pathWithoutLocale;
let ruSlug = pathWithoutLocale;

let isServicePage = false;
for (const [ru, en] of Object.entries(servicePairs)) {
    if (cleanPath === `/uslugi/${ru}`) {
        enSlug = `/services/${en}`;
        ruSlug = `/uslugi/${ru}`;
        isServicePage = true;
        break;
    }
    if (cleanPath === `/services/${en}`) {
        enSlug = `/services/${en}`;
        ruSlug = `/uslugi/${ru}`;
        isServicePage = true;
        break;
    }
}

if (!isServicePage) {
    enSlug = pathWithoutLocale.replace(/^\/uslugi/, '/services');
    ruSlug = pathWithoutLocale.replace(/^\/services/, '/uslugi');
}

// Detect geo city pages and check if they have RU content
const ruCityGeoMatch = cleanPath.match(/^\/uslugi\/([^/]+)$/);
const enCityGeoMatch = cleanPath.match(/^\/services\/([^/]+)$/);
const geoCitySlug = ruCityGeoMatch?.[1] ?? enCityGeoMatch?.[1] ?? null;

let geoHasRU = true;
let geoHasEN = true;
if (geoCitySlug) {
    const locData = locations.find(l => l.slug === geoCitySlug);
    geoHasRU = !!locData?.name_ru && !!(geoContent as any)[geoCitySlug]?.ru;
    geoHasEN = !!(geoContent as any)[geoCitySlug]?.en;
    // For geo pages: build the correct cross-lang URLs
    enSlug = `/services/${geoCitySlug}`;
    ruSlug = `/uslugi/${geoCitySlug}`;
}

const siteBase = Astro.site ? Astro.site.toString() : 'https://avpdev.com';
const ruUrl = new URL(`ru${ruSlug.endsWith('/') ? ruSlug : ruSlug + '/'}`, siteBase).href;
const enUrl = new URL(`en${enSlug.endsWith('/') ? enSlug : enSlug + '/'}`, siteBase).href;
const xDefaultUrl = new URL('/', siteBase).href;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />
    
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AVPdev.com" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />


    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#030305">

    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2">
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png?v=2">
    <link rel="manifest" href="/site.webmanifest?v=2">

    {/* FontAwesome CDN: required for techStack icons (fab) and UI components (fas). 
        Loaded non-blocking using media="print" trick to prevent Lighthouse warnings. */}
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <style>
        @font-face { font-family: "Font Awesome 6 Free"; font-style: normal; font-weight: 900; font-display: swap; src: url(https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/webfonts/fa-solid-900.woff2) format("woff2"); }
        @font-face { font-family: "Font Awesome 6 Brands"; font-style: normal; font-weight: 400; font-display: swap; src: url(https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/webfonts/fa-brands-400.woff2) format("woff2"); }
    </style>
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" as="style" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" media="print" onload="this.media='all'" />
    <noscript>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    </noscript>

    {schema && (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    
    <slot name="head" />



    {GTAG_ID && (
        <>
            {/* Google Analytics & Yandex.Metrika - deferred loading to improve performance and prevent layout thrashing */}
            <script define:vars={{ GTAG_ID }}>
              window.analyticsLoaded = false;
              
              // 1. Синхронное объявление функций (чтобы боты аналитики видели свое присутствие сразу)
              // Google Analytics Init
              window.dataLayer = window.dataLayer || [];
              function gtag(){dataLayer.push(arguments);}
              gtag('js', new Date());
              gtag('config', GTAG_ID, { 'send_page_view': false });

              // Yandex.Metrika Init
              const ymId = 107147089;
              (function(m,e,t,r,i,k,a){
                  m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
                  m[i].l=1*new Date();
              })(window, document,'script','https://mc.yandex.ru/metrika/tag.js', 'ym');

              ym(ymId, 'init', {
                  clickmap:true,
                  trackLinks:true,
                  accurateTrackBounce:true,
                  webvisor:true,
                  ecommerce:"dataLayer", 
                  referrer: document.referrer, 
                  url: location.href,
                  ssr:true
              });

              // 2. Асинхронная загрузка тяжелых скриптов (отложено или по клику/скроллу)
              const loadAnalyticsConfigs = () => {
                if (window.analyticsLoaded) return;
                window.analyticsLoaded = true;
                
                // Загружаем скрипт GA
                const scriptGA = document.createElement('script');
                scriptGA.src = `https://www.googletagmanager.com/gtag/js?id=${GTAG_ID}`;
                scriptGA.async = true;
                document.head.appendChild(scriptGA);

                // Загружаем скрипт Yandex.Metrika
                const scriptYM = document.createElement('script');
                scriptYM.src = 'https://mc.yandex.ru/metrika/tag.js';
                scriptYM.async = true;
                document.head.appendChild(scriptYM);
              };

              // Откладываем тяжелые скрипты
              setTimeout(loadAnalyticsConfigs, 3500);
              const interactionEvents = ['scroll', 'click', 'mousemove', 'touchstart'];
              interactionEvents.forEach(e => window.addEventListener(e, loadAnalyticsConfigs, { once: true, passive: true }));
            </script>
            <noscript><div><img src="https://mc.yandex.ru/watch/107147089" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
        </>
    )}

    {(!geoCitySlug || geoHasRU) && <link rel="alternate" hreflang="ru" href={ruUrl} />}
    {(!geoCitySlug || geoHasEN) && <link rel="alternate" hreflang="en" href={enUrl} />}
    {(!geoCitySlug || geoHasRU) && <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />}
    {geoCitySlug && !geoHasRU && <link rel="alternate" hreflang="x-default" href={enUrl} />}

    <script is:inline>
        function applyTheme() {
            const theme = (() => {
                if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                    return localStorage.getItem('theme');
                }
                if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    return 'dark-theme';
                }
                return 'light-theme';
            })();
            
            if (theme === 'dark-theme') {
                document.documentElement.classList.add('dark-theme');
                document.documentElement.classList.remove('light-theme');
                document.documentElement.style.colorScheme = 'dark';
            } else {
                document.documentElement.classList.add('light-theme');
                document.documentElement.classList.remove('dark-theme');
                document.documentElement.style.colorScheme = 'light';
            }
            window.localStorage.setItem('theme', theme);
        }

        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
    </script>

    {/* Уничтожение старых Service Workers, которые ломают редиректы и кешируют старые страницы */}
    <script is:inline>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then(function(registrations) {
                for(let registration of registrations) {
                    registration.unregister();
                }
            }).catch(function(err) {
                console.log('Service Worker unregistration failed: ', err);
            });
        }
    </script>


    <ClientRouter />

    <style is:inline>
        /* --- Critical CSS for FOUC prevention --- */
        :root {
            --accent-gradient: linear-gradient(135deg, #FF5C00 0%, #FFB800 100%);
            --accent-color-start: #FF5C00;
            --accent-color-start-rgb: 255, 92, 0;
            --accent-color-end: #FFB800;
            --font-heading: 'Sora Variable', sans-serif;
            --font-body: 'Plus Jakarta Sans Variable', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
        }

        /* Critical CSS for LCP (Logo) */
        header {
            position: fixed;
            top: 1.25rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1005;
            display: block;
        }
        .logo {
            font-size: 1.25rem;
            font-weight: 800;
            text-decoration: none;
            color: var(--text-color);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .logo-img {
            height: 32px;
            width: auto;
            aspect-ratio: 40/40;
        }
        .logo-text {
            font-family: var(--font-heading);
            font-weight: 800;
            line-height: 1;
        }

        /* Default background to avoid white flash */
        html {
            background-color: #050505;
            color-scheme: dark; /* Default */
        }

        .light-theme {
            color-scheme: light;
            --bg-color: #FAFAFA;
            --bg-color-rgb: 250, 250, 250;
            --primary-color: #FFFFFF;
            --primary-color-rgb: 255, 255, 255;
            --text-color: #18181B;
            --text-secondary-color: #52525B;
            --accent-color: #FF5C00;
            --border-color: rgba(0, 0, 0, 0.08);
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(0, 0, 0, 0.05);
            --card-shadow: 
                0 2px 4px rgba(0, 0, 0, 0.02), 
                0 4px 8px rgba(0, 0, 0, 0.02), 
                0 8px 16px rgba(0, 0, 0, 0.03), 
                0 16px 32px rgba(0, 0, 0, 0.04);
            --particle-color: "#222222";
            --particle-line-color: "#333333";
            --tag-bg: rgba(0, 0, 0, 0.05);
            --tag-text: #3F3F46;
        }

        .dark-theme {
            color-scheme: dark;
            --bg-color: #030305;
            --bg-color-rgb: 3, 3, 5;
            --primary-color: #11111A;
            --primary-color-rgb: 17, 17, 26;
            --text-color: #FFFFFF;
            --text-secondary-color: #94949E;
            --accent-color: #FFB800;
            --border-color: rgba(255, 255, 255, 0.1);
            --glass-bg: rgba(17, 17, 26, 0.8);
            --glass-border: rgba(255, 255, 255, 0.15);
            --card-shadow: 
                0 4px 8px rgba(0, 0, 0, 0.6), 
                0 8px 16px rgba(0, 0, 0, 0.6), 
                0 16px 32px rgba(0, 0, 0, 0.7), 
                0 32px 64px rgba(0, 0, 0, 0.8);
            --particle-color: "#ffffff";
            --particle-line-color: "#ffffff";
            --tag-bg: rgba(255, 255, 255, 0.08);
            --tag-text: #E4E4E7;
        }

        html.light-theme { background-color: #FAFAFA; }
        html.dark-theme { background-color: #030305; }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: var(--font-body);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            margin: 0;
            position: relative;
        }

        /* Standardized transition for theme switch button only */
        .theme-transitioning body {
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(circle at 2px 2px, rgba(255, 255, 255, 0.03) 1px, transparent 0);
            background-size: 40px 40px;
            pointer-events: none;
            z-index: -1;
        }
        .dark-theme body::before {
            background-image: 
                radial-gradient(circle at 2px 2px, rgba(255, 255, 255, 0.02) 1px, transparent 0);
        }
        .light-theme body::before {
            background-image: 
                radial-gradient(circle at 2px 2px, rgba(0, 0, 0, 0.02) 1px, transparent 0);
        }
        h1, h2, h3, h4, h5, h6 {
            font-family: var(--font-heading);
            font-weight: 700;
            letter-spacing: -0.02em;
        }
    </style>
</head>
<body>
    <Header />
    
    <main class="flex-grow pt-[80px]"> <!-- pt-[80px] to account for fixed header -->
      <slot />
    </main>

    <Footer />

    <!-- Floating Action Button (FAB) -->
    <a href="https://t.me/AVP_Dev" target="_blank" rel="noopener noreferrer" class="fab-contact" aria-label="Contact Telegram" onclick="if(window.gtag) window.gtag('event', 'click_telegram'); if(window.ym) window.ym(107147089, 'reachGoal', 'click_telegram');">
      <i class="fa-brands fa-telegram-plane"></i>
    </a>
    <!-- Lightbox Modal -->
    <div id="lightbox" class="lightbox" aria-hidden="true" role="dialog">
        <button class="lightbox-close" aria-label="Close Lightbox">&times;</button>
        <div class="lightbox-loader"></div>
        <div class="lightbox-content">
            <img id="lightbox-img" src="" alt="Full size image" />
            <div id="lightbox-caption" class="lightbox-caption"></div>
        </div>
    </div>

    <ScrollToTop />
    <script src="/src/scripts/main.ts"></script>
</body>
</html>