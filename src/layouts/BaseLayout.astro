---
import { ClientRouter } from 'astro:transitions';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import type { ui } from '../i18n/ui';
import { locations } from '../data/locations';
import { geoContent } from '../data/geo-content';

// --- ШРИФТЫ (Self-hosted) ---
import '@fontsource-variable/sora';
import '@fontsource-variable/plus-jakarta-sans';
import '@fontsource/jetbrains-mono';

import '../styles/style.css';
import '../styles/case-study.css';
import '../styles/blog.css';

export interface Props {
	title: string;
	description: string;
    ogImage?: string;
    isTranslationKey?: boolean;
    schema?: Record<string, any>;
}

const {
    title,
    description,
    ogImage = '/og-image.webp',
    isTranslationKey = true,
    schema,
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const finalTitle = isTranslationKey ? t(title as any) : title;
const finalDescription = isTranslationKey ? t(description as any) : description;

const canonicalURL = new URL(Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`, Astro.site);
const GTAG_ID = import.meta.env.PUBLIC_GTAG_ID;

// SEO: Hreflang Tags Logic
let currentPath = Astro.url.pathname;
if (!currentPath.endsWith('/')) { currentPath += '/'; }

const pathWithoutLocale = currentPath.replace(/^\/(ru|en)\//, '/');
const cleanPath = pathWithoutLocale.endsWith('/') ? pathWithoutLocale.slice(0, -1) : pathWithoutLocale;

const servicePairs = {
    'razrabotka-saitov': 'website-development',
    'ai-integracii': 'ai-integration',
    'razrabotka-botov-i-parserov': 'bot-and-scraper-development',
    'telegram-mini-apps': 'telegram-mini-apps',
    'saas-mvp': 'saas-mvp'
};

let enSlug = pathWithoutLocale;
let ruSlug = pathWithoutLocale;

let isServicePage = false;
for (const [ru, en] of Object.entries(servicePairs)) {
    if (cleanPath === `/uslugi/${ru}`) {
        enSlug = `/services/${en}`;
        ruSlug = `/uslugi/${ru}`;
        isServicePage = true;
        break;
    }
    if (cleanPath === `/services/${en}`) {
        enSlug = `/services/${en}`;
        ruSlug = `/uslugi/${ru}`;
        isServicePage = true;
        break;
    }
}

if (!isServicePage) {
    enSlug = pathWithoutLocale.replace(/^\/uslugi/, '/services');
    ruSlug = pathWithoutLocale.replace(/^\/services/, '/uslugi');
}

// Detect geo city pages and check if they have RU content
const ruCityGeoMatch = cleanPath.match(/^\/uslugi\/([^/]+)$/);
const enCityGeoMatch = cleanPath.match(/^\/services\/([^/]+)$/);
const geoCitySlug = ruCityGeoMatch?.[1] ?? enCityGeoMatch?.[1] ?? null;

let geoHasRU = true;
let geoHasEN = true;
if (geoCitySlug) {
    const locData = locations.find(l => l.slug === geoCitySlug);
    geoHasRU = !!locData?.name_ru && !!(geoContent as any)[geoCitySlug]?.ru;
    geoHasEN = !!(geoContent as any)[geoCitySlug]?.en;
    // For geo pages: build the correct cross-lang URLs
    enSlug = `/services/${geoCitySlug}`;
    ruSlug = `/uslugi/${geoCitySlug}`;
}

const siteBase = Astro.site ? Astro.site.toString() : 'https://avpdev.com';
const ruUrl = new URL(`ru${ruSlug.endsWith('/') ? ruSlug : ruSlug + '/'}`, siteBase).href;
const enUrl = new URL(`en${enSlug.endsWith('/') ? enSlug : enSlug + '/'}`, siteBase).href;
const xDefaultUrl = new URL('/', siteBase).href;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />
    
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AVPdev.com" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />


    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="theme-color" content="#030305">

    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2">
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png?v=2">
    <link rel="manifest" href="/site.webmanifest?v=2">

    {/* FontAwesome CDN: required for techStack icons (fab) and UI components (fas). 
        Loaded non-blocking using media="print" trick to prevent Lighthouse warnings. */}
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <style>
        @font-face { font-family: "Font Awesome 6 Free"; font-style: normal; font-weight: 900; font-display: swap; src: url(https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/webfonts/fa-solid-900.woff2) format("woff2"); }
        @font-face { font-family: "Font Awesome 6 Brands"; font-style: normal; font-weight: 400; font-display: swap; src: url(https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/webfonts/fa-brands-400.woff2) format("woff2"); }
    </style>
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" as="style" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" media="print" onload="this.media='all'" />
    <noscript>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    </noscript>

    {schema && (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
    
    <slot name="head" />



    {GTAG_ID && (
        <>
            {/* Analytics Initialization (Deferred for PageSpeed) */}
            <script define:vars={{ GTAG_ID }}>
              const loadAnalytics = () => {
                if (window.analyticsInjected) return;
                window.analyticsInjected = true;

                // Load GA4
                const scriptGA = document.createElement('script');
                scriptGA.src = `https://www.googletagmanager.com/gtag/js?id=${GTAG_ID}`;
                scriptGA.async = true;
                document.head.appendChild(scriptGA);

                window.dataLayer = window.dataLayer || [];
                function gtag(){dataLayer.push(arguments);}
                gtag('js', new Date());
                gtag('config', GTAG_ID, { 'send_page_view': false });

                // Load Yandex.Metrika
                const ymId = 107147089;
                const scriptYM = document.createElement('script');
                scriptYM.src = 'https://mc.yandex.ru/metrika/tag.js';
                scriptYM.async = true;
                document.head.appendChild(scriptYM);

                (function(m,e,t,r,i,k,a){
                    m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
                })(window, document,'script','https://mc.yandex.ru/metrika/tag.js', 'ym');

                ym(ymId, 'init', {
                    clickmap:true,
                    trackLinks:true,
                    accurateTrackBounce:true,
                    webvisor:true,
                    ecommerce:"dataLayer", 
                    referrer: document.referrer, 
                    url: location.href,
                    ssr:true
                });
              };
              
              // Delayed inject of heavy scripts
              setTimeout(loadAnalytics, 3000);
              ['scroll', 'click', 'mousemove', 'touchstart'].forEach(e => 
                  window.addEventListener(e, loadAnalytics, { once: true, passive: true })
              );
            </script>
            <noscript><div><img src="https://mc.yandex.ru/watch/107147089" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
        </>
    )}

    <script src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js" defer></script>
    <script define:vars={{ ONESIGNAL_APP_ID: import.meta.env.PUBLIC_ONESIGNAL_APP_ID, lang }}>
      window.OneSignalDeferred = window.OneSignalDeferred || [];
      OneSignalDeferred.push(function(OneSignal) {
        const isRu = lang === 'ru';
        
        OneSignal.init({
          appId: ONESIGNAL_APP_ID || "41f312d7-7d44-4ed0-a813-5d96fbfa4deb",
          safari_web_id: "web.onesignal.auto.10b8f047-9750-48e7-9191-28564a938883",
          autoResubscribe: true,
          notifyButton: { enable: false }, // Disable standard bell
          promptOptions: { slidedown: { enabled: false } }, // Disable standard slidedown
          allowLocalhostAsSecureOrigin: true,
        });

        // Custom Prompt Logic
        async function checkAndShowPrompt() {
          const isPushSupported = OneSignal.Notifications.isPushSupported();
          const permission = OneSignal.Notifications.permission;
          
          // Don't show if not supported or already granted/denied
          if (!isPushSupported || permission !== 'default') return;

          // Check if user dismissed it recently in this session
          if (sessionStorage.getItem('notif_prompt_dismissed')) return;

          const prompt = document.getElementById('custom-notif-prompt');
          if (!prompt) return;

          setTimeout(() => {
            prompt.classList.add('active');
          }, 3000); // 3 seconds delay
        }

        OneSignal.Notifications.addEventListener('permissionChange', (permission) => {
          if (permission) {
             document.getElementById('custom-notif-prompt')?.classList.remove('active');
          }
        });

        window.handleNotifAction = (action) => {
          const prompt = document.getElementById('custom-notif-prompt');
          if (action === 'subscribe') {
            OneSignal.Notifications.requestPermission();
          } else {
            sessionStorage.setItem('notif_prompt_dismissed', 'true');
          }
          prompt?.classList.remove('active');
        };

        checkAndShowPrompt();
      });
    </script>

    <style is:global>
        /* Custom Notification Prompt Styling */
        .custom-notif-prompt {
            position: fixed;
            top: -120%;
            left: 50%;
            transform: translateX(-50%);
            width: 90%;
            max-width: 500px;
            background: rgba(17, 17, 26, 0.9);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 184, 0, 0.3);
            border-radius: 20px;
            padding: 20px;
            z-index: 9999;
            transition: top 0.6s cubic-bezier(0.68, -0.55, 0.27, 1.55);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.8), 0 0 20px rgba(255, 184, 0, 0.1);
        }
        .custom-notif-prompt.active {
            top: 24px;
        }
        .prompt-content {
            display: flex;
            align-items: center;
            gap: 20px;
        }
        .prompt-icon {
            width: 48px;
            height: 48px;
            background: var(--accent-gradient);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: #11111A;
            flex-shrink: 0;
            animation: bell-bounce 2s infinite;
        }
        .prompt-text h3 {
            margin: 0 0 4px 0;
            font-size: 1rem;
            color: #FFFFFF;
        }
        .prompt-text p {
            margin: 0;
            font-size: 0.85rem;
            color: #94949E;
            line-height: 1.4;
        }
        .prompt-actions {
            display: flex;
            gap: 12px;
            margin-left: auto;
        }
        .prompt-actions button {
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s ease;
            white-space: nowrap;
        }
        .btn-later {
            background: transparent;
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #94949E;
        }
        .btn-subscribe {
            background: #FFB800;
            border: none;
            color: #11111A;
        }
        .btn-subscribe:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(255, 184, 0, 0.3);
        }

        @keyframes bell-bounce {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1) rotate(10deg); }
        }

        @media (max-width: 640px) {
            .custom-notif-prompt {
                bottom: -100%;
                top: auto;
                transition: bottom 0.6s cubic-bezier(0.68, -0.55, 0.27, 1.55);
            }
            .custom-notif-prompt.active {
                bottom: 24px;
                top: auto;
            }
            .prompt-content {
                flex-direction: column;
                text-align: center;
                gap: 16px;
            }
            .prompt-actions {
                width: 100%;
                margin-left: 0;
            }
            .prompt-actions button {
                flex: 1;
            }
        }
    </style>

    {(!geoCitySlug || geoHasRU) && <link rel="alternate" hreflang="ru" href={ruUrl} />}
    {(!geoCitySlug || geoHasEN) && <link rel="alternate" hreflang="en" href={enUrl} />}
    {(!geoCitySlug || geoHasRU) && <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />}
    {geoCitySlug && !geoHasRU && <link rel="alternate" hreflang="x-default" href={enUrl} />}

    <script is:inline>
        function applyTheme() {
            const theme = (() => {
                if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
                    return localStorage.getItem('theme');
                }
                if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
                    return 'dark-theme';
                }
                return 'light-theme';
            })();
            
            if (theme === 'dark-theme') {
                document.documentElement.classList.add('dark-theme');
                document.documentElement.classList.remove('light-theme');
                document.documentElement.style.colorScheme = 'dark';
            } else {
                document.documentElement.classList.add('light-theme');
                document.documentElement.classList.remove('dark-theme');
                document.documentElement.style.colorScheme = 'light';
            }
            window.localStorage.setItem('theme', theme);
        }

        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);

        // --- UTM Tracker ---
        function trackUtmParams() {
            const urlParams = new URLSearchParams(window.location.search);
            const utmParams = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
            let hasNewParams = false;
            let currentUtms = {};

            try {
                const stored = localStorage.getItem('utm_data');
                if (stored) currentUtms = JSON.parse(stored);
            } catch (e) {}

            utmParams.forEach(param => {
                if (urlParams.has(param)) {
                    currentUtms[param] = urlParams.get(param);
                    hasNewParams = true;
                }
            });

            if (hasNewParams) {
                currentUtms.timestamp = new Date().toISOString();
                localStorage.setItem('utm_data', JSON.stringify(currentUtms));
            }
        }
        
        // Add global helper to read UTMs for forms
        window.getUtmParams = function() {
            try {
                const stored = localStorage.getItem('utm_data');
                return stored ? JSON.parse(stored) : null;
            } catch (e) {
                return null;
            }
        };

        trackUtmParams();
        document.addEventListener('astro:page-load', trackUtmParams);
    </script>
    </script>



    <ClientRouter />

    <style is:inline>
        /* --- Critical CSS for FOUC prevention --- */
        :root {
            --accent-gradient: linear-gradient(135deg, #FF5C00 0%, #FFB800 100%);
            --accent-color-start: #FF5C00;
            --accent-color-start-rgb: 255, 92, 0;
            --accent-color-end: #FFB800;
            --font-heading: 'Sora Variable', sans-serif;
            --font-body: 'Plus Jakarta Sans Variable', sans-serif;
            --font-mono: 'JetBrains Mono', monospace;
        }

        /* Critical CSS for LCP (Logo) */
        header {
            position: fixed;
            top: 1.25rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 1005;
            display: block;
        }
        .logo {
            font-size: 1.25rem;
            font-weight: 800;
            text-decoration: none;
            color: var(--text-color);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .logo-img {
            height: 32px;
            width: auto;
            aspect-ratio: 40/40;
        }
        .logo-text {
            font-family: var(--font-heading);
            font-weight: 800;
            line-height: 1;
        }

        /* Default background to avoid white flash */
        html {
            background-color: #050505;
            color-scheme: dark; /* Default */
        }

        .light-theme {
            color-scheme: light;
            --bg-color: #FAFAFA;
            --bg-color-rgb: 250, 250, 250;
            --primary-color: #FFFFFF;
            --primary-color-rgb: 255, 255, 255;
            --text-color: #18181B;
            --text-secondary-color: #52525B;
            --accent-color: #FF5C00;
            --border-color: rgba(0, 0, 0, 0.08);
            --glass-bg: rgba(255, 255, 255, 0.7);
            --glass-border: rgba(0, 0, 0, 0.05);
            --card-shadow: 
                0 2px 4px rgba(0, 0, 0, 0.02), 
                0 4px 8px rgba(0, 0, 0, 0.02), 
                0 8px 16px rgba(0, 0, 0, 0.03), 
                0 16px 32px rgba(0, 0, 0, 0.04);
            --particle-color: "#222222";
            --particle-line-color: "#333333";
            --tag-bg: rgba(0, 0, 0, 0.05);
            --tag-text: #3F3F46;
        }

        .dark-theme {
            color-scheme: dark;
            --bg-color: #030305;
            --bg-color-rgb: 3, 3, 5;
            --primary-color: #11111A;
            --primary-color-rgb: 17, 17, 26;
            --text-color: #FFFFFF;
            --text-secondary-color: #94949E;
            --accent-color: #FFB800;
            --border-color: rgba(255, 255, 255, 0.1);
            --glass-bg: rgba(17, 17, 26, 0.8);
            --glass-border: rgba(255, 255, 255, 0.15);
            --card-shadow: 
                0 4px 8px rgba(0, 0, 0, 0.6), 
                0 8px 16px rgba(0, 0, 0, 0.6), 
                0 16px 32px rgba(0, 0, 0, 0.7), 
                0 32px 64px rgba(0, 0, 0, 0.8);
            --particle-color: "#ffffff";
            --particle-line-color: "#ffffff";
            --tag-bg: rgba(255, 255, 255, 0.08);
            --tag-text: #E4E4E7;
        }

        html.light-theme { background-color: #FAFAFA; }
        html.dark-theme { background-color: #030305; }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            font-family: var(--font-body);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            margin: 0;
            position: relative;
        }

        /* Standardized transition for theme switch button only */
        .theme-transitioning body {
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                radial-gradient(circle at 2px 2px, rgba(255, 255, 255, 0.03) 1px, transparent 0);
            background-size: 40px 40px;
            pointer-events: none;
            z-index: -1;
        }
        .dark-theme body::before {
            background-image: 
                radial-gradient(circle at 2px 2px, rgba(255, 255, 255, 0.02) 1px, transparent 0);
        }
        .light-theme body::before {
            background-image: 
                radial-gradient(circle at 2px 2px, rgba(0, 0, 0, 0.02) 1px, transparent 0);
        }
        h1, h2, h3, h4, h5, h6 {
            font-family: var(--font-heading);
            font-weight: 700;
            letter-spacing: -0.02em;
        }
    </style>
</head>
<body>
    <Header />
    
    <main class="flex-grow pt-[80px]"> <!-- pt-[80px] to account for fixed header -->
      <slot />
    </main>

    <Footer />

    <!-- Floating Action Button (FAB) -->
    <a href="https://t.me/AVP_Dev" target="_blank" rel="noopener noreferrer" class="fab-contact" aria-label="Contact Telegram" onclick="if(window.gtag) window.gtag('event', 'click_telegram'); if(window.ym) window.ym(107147089, 'reachGoal', 'click_telegram');">
      <i class="fa-brands fa-telegram-plane"></i>
    </a>
    <!-- Lightbox Modal -->
    <div id="lightbox" class="lightbox" aria-hidden="true" role="dialog">
        <button class="lightbox-close" aria-label="Close Lightbox">&times;</button>
        <div class="lightbox-loader"></div>
        <div class="lightbox-content">
            <img id="lightbox-img" src="" alt="Full size image" />
            <div id="lightbox-caption" class="lightbox-caption"></div>
        </div>
    </div>

    <ScrollToTop />
    <script src="/src/scripts/main.ts"></script>

    <!-- Custom Premium Notification Prompt -->
    <div id="custom-notif-prompt" class="custom-notif-prompt">
        <div class="prompt-content">
            <div class="prompt-icon">
                <i class="fa-solid fa-bell"></i>
            </div>
            <div class="prompt-text">
                <h3>{lang === 'ru' ? 'Свежие кейсы и гайды' : 'Fresh Cases & Guides'}</h3>
                <p>{lang === 'ru' ? 'Хотите получать уведомления о новых публикациях?' : 'Would you like to get notified about new publications?'}</p>
            </div>
            <div class="prompt-actions">
                <button onclick="handleNotifAction('later')" class="btn-later">{lang === 'ru' ? 'Позже' : 'Later'}</button>
                <button onclick="handleNotifAction('subscribe')" class="btn-subscribe">{lang === 'ru' ? 'Разрешить' : 'Allow'}</button>
            </div>
        </div>
    </div>
</body>
</html>