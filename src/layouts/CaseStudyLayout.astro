---
// src/layouts/CaseStudyLayout.astro
import BaseLayout from './BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { ui } from '../i18n/ui';

export interface Props {
    title: keyof typeof ui['ru'];
    description: keyof typeof ui['ru'];
    ogImage: string;
    clientKey: keyof typeof ui['ru'];
    servicesKey: keyof typeof ui['ru'];
    year: string | number;
    heroImage: string;
    heroImageAlt: string;
}

const {
    title,
    description,
    ogImage,
    clientKey,
    servicesKey,
    year,
    heroImage,
    heroImageAlt
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const homePath = `/${lang}/`;
---
<BaseLayout title={title} description={description} ogImage={ogImage}>
    <section class="case-study-header">
        <div class="container">
            <!-- Заголовок и описание будут переданы из конкретной страницы кейса -->
            <slot name="header" />
            <div class="project-details">
                <div class="detail-item">
                    <h4>{t('case_client')}</h4>
                    <p>{t(clientKey)}</p>
                </div>
                <div class="detail-item">
                    <h4>{t('case_services')}</h4>
                    <p>{t(servicesKey)}</p>
                </div>
                <div class="detail-item">
                    <h4>{t('case_year')}</h4>
                    <p>{year}</p>
                </div>
            </div>
        </div>
    </section>

    <div class="container">
        <img src={heroImage} alt={heroImageAlt} class="main-project-image" loading="lazy">
    </div>

    <div class="project-content-wrapper">
        <div class="project-content">
            <!-- Основной контент кейса -->
            <slot name="content" />

            <div class="case-cta-section">
                 <a href={`${homePath}#contact`} class="cta-button">{t('case_cta_discuss')}</a>
            </div>
            <a href={`${homePath}#portfolio`} class="back-to-main">{t('back_to_portfolio')}</a>
        </div>
    </div>
</BaseLayout>