---
// src/pages/ru/privacy-policy.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

export const prerender = true;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<BaseLayout
    title="privacy_policy_title"
    description="privacy_policy_desc"
>
    <main class="legal-page-content">
        <div class="container legal-container">
            <h1 set:html={t('privacy_policy_h1')}></h1>
            <p class="last-updated"><strong set:html={t('privacy_policy_last_updated_label')}></strong> <span set:html={t('privacy_policy_last_updated_date')}></span></p>

            <p set:html={t('privacy_policy_intro_p1')}></p>
            <p set:html={t('privacy_policy_intro_p2')}></p>

            <h3 set:html={t('privacy_policy_s1_title')}></h3>
            <p set:html={t('privacy_policy_s1_p1')}></p>
            <p set:html={t('privacy_policy_s1_p2')}></p>
            <p set:html={t('privacy_policy_s1_p3')}></p>
            <p set:html={t('privacy_policy_s1_p4')}></p>
            <p set:html={t('privacy_policy_s1_p5')}></p>

            <h3 set:html={t('privacy_policy_s2_title')}></h3>
            <p set:html={t('privacy_policy_s2_p1')}></p>
            <ul>
                <li set:html={t('privacy_policy_s2_li1')}></li>
                <li set:html={t('privacy_policy_s2_li2')}></li>
                <li set:html={t('privacy_policy_s2_li3')}></li>
            </ul>
            <p set:html={t('privacy_policy_s2_p2')}></p>
            <ul>
                <li set:html={t('privacy_policy_s2_li4')}></li>
                <li set:html={t('privacy_policy_s2_li5')}></li>
                <li set:html={t('privacy_policy_s2_li6')}></li>
                <li set:html={t('privacy_policy_s2_li7')}></li>
            </ul>
            <p set:html={t('privacy_policy_s2_p3')}></p>

            <h3 set:html={t('privacy_policy_s3_title')}></h3>
            <p set:html={t('privacy_policy_s3_p1')}></p>
            <ul>
                <li set:html={t('privacy_policy_s3_li1')}></li>
                <li set:html={t('privacy_policy_s3_li2')}></li>
                <li set:html={t('privacy_policy_s3_li3')}></li>
                <li set:html={t('privacy_policy_s3_li4')}></li>
                <li set:html={t('privacy_policy_s3_li5')}></li>
            </ul>

            <h3 set:html={t('privacy_policy_s4_title')}></h3>
            <p set:html={t('privacy_policy_s4_p1')}></p>
            <ul>
                <li set:html={t('privacy_policy_s4_li1')}></li>
                <li set:html={t('privacy_policy_s4_li2')}></li>
                <li set:html={t('privacy_policy_s4_li3')}></li>
                <li set:html={t('privacy_policy_s4_li4')}></li>
                <li set:html={t('privacy_policy_s4_li5')}></li>
            </ul>
            <p set:html={t('privacy_policy_s4_p2')}></p>

            <h3 set:html={t('privacy_policy_s5_title')}></h3>
            <p set:html={t('privacy_policy_s5_p1')}></p>
            <p set:html={t('privacy_policy_s5_p2')}></p>
            <p set:html={t('privacy_policy_s5_p3')}></p>

            <h3 set:html={t('privacy_policy_s6_title')}></h3>
            <p set:html={t('privacy_policy_s6_p1')}></p>

            <h3 set:html={t('privacy_policy_s7_title')}></h3>
            <p set:html={t('privacy_policy_s7_p1')}></p>
            <p set:html={t('privacy_policy_s7_p2')}></p>
            <ul class="contact-methods">
                <li set:html={t('privacy_policy_s7_li1')}></li>
                <li set:html={t('privacy_policy_s7_li2')}></li>
                <li set:html={t('privacy_policy_s7_li3')}></li>
                <li set:html={t('privacy_policy_s7_li4')}></li>
            </ul>

            <a href={`/${lang}/`} class="back-to-main" set:html={t('back_to_home')}></a>
        </div>
    </main>
</BaseLayout>

<style is:global>
    .legal-page-content {
        padding-top: 120px;
        padding-bottom: 80px;
    }
    .legal-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem;
        background-color: var(--primary-color);
        border-radius: 15px;
        border: var(--glass-border);
    }
    .legal-container h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
    .legal-container h3 { font-size: 1.8rem; margin-top: 2.5rem; margin-bottom: 1rem; }
    .legal-container p, .legal-container ul { line-height: 1.8; color: var(--text-secondary-color); margin-bottom: 1rem; }
    .legal-container ul { padding-left: 20px; }
    .legal-container a { color: var(--accent-color-start); }
    .legal-container .last-updated { margin-bottom: 2rem; }
</style>