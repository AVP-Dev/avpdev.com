---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/sections/Hero.astro';
import Contact from '../../../components/sections/Contact.astro';

const seoTitle = "Разработка сайтов под ключ: Лендинги, Магазины, Порталы | AVPdev";
const seoDescription = "Создаем высокопроизводительные сайты на Next.js, Astro и React. От продающих лендингов до сложных маркетплейсов и корпоративных порталов.";

const serviceFeatures = [
  {
    title: "Лендинги и Промо-сайты",
    desc: "Максимальная конверсия и скорость загрузки. Идеально для запуска рекламы и презентации продукта.",
    icon: "fa-rocket"
  },
  {
    title: "Корпоративные сайты",
    desc: "Ваше цифровое представительство. Сложная структура, интеграция с CRM и уникальный дизайн.",
    icon: "fa-building"
  },
  {
    title: "Интернет-магазины",
    desc: "Масштабируемые решения для E-commerce. Каталоги, корзины, платежные системы и учет остатков.",
    icon: "fa-cart-shopping"
  },
  {
    title: "Блоги и Медиа-порталы",
    desc: "Удобные системы управления контентом и SEO-оптимизация 'из коробки' для высоких позиций в поиске.",
    icon: "fa-newspaper"
  }
];

const faqs = [
  {
    q: "На каком стеке вы разрабатываете сайты?",
    a: "Мы предпочитаем современный стек: Next.js или Astro для фронтенда (это дает топовую скорость загрузки и SEO) и Node.js для серверной части."
  },
  {
    q: "Сколько времени занимает разработка?",
    a: "Простой лендинг можно разработать за 7-10 дней. Сложный корпоративный сайт, портал или интернет-магазин обычно требуют от 3 до 6 недель, в зависимости от объема необходимого функционала и интеграций."
  },
  {
    q: "Будет ли сайт адаптирован под мобильные устройства?",
    a: "Абсолютно. В наши дни мобильный трафик преобладает, поэтому 100% наших сайтов имеют полностью адаптивный дизайн (Mobile First) и корректно отображаются на любых смартфонах и планшетах."
  },
  {
    q: "Предоставляете ли вы домен и хостинг?",
    a: "Мы помогаем клиентам с выбором и регистрацией доменного имени, а также настраиваем надёжный и быстрый хостинг или VPS под ключ, чтобы вам не пришлось разбираться в технических деталях."
  },
  {
    q: "Занимаетесь ли вы SEO-продвижением?",
    a: "Все наши сайты разрабатываются с учетом базовой SEO-оптимизации (скорость, семантическая разметка, мета-теги). Это дает отличный старт для дальнейшего глубокого SEO-продвижения в Google и Яндекс."
  },
  {
    q: "Можно ли будет редактировать контент самостоятельно?",
    a: "Да, мы интегрируем удобные и современные системы управления контентом (CMS или Headless CMS), которые позволяют вам легко менять тексты, фото и добавлять новые страницы без знания кода."
  },
  {
    q: "Что происходит после запуска проекта?",
    a: "Мы не бросаем проекты после релиза. Мы предлагаем техническую поддержку, гарантийное обслуживание и помощь в дальнейшем развитии функционала вашего сайта по мере роста вашего бизнеса."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Разработка сайтов под ключ",
      "description": seoDescription,
      "provider": {
        "@type": "Person",
        "name": "Алексей Пацкевич"
      },
      "areaServed": "Worldwide",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Типы сайтов",
        "itemListElement": serviceFeatures.map(f => ({
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": f.title,
            "description": f.desc
          }
        }))
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  schema={schema}
>
  <Hero 
    title="Разработка современных сайтов"
    subtitle="Создаем быстрые, красивые и эффективные решения для вашего бизнеса. От идеи до запуска."
    variant="services"
  />

  <section class="services-info">
    <div class="container">
      <div class="section-content-split">
        <div class="text-content">
          <span class="section-label">Web Solutions</span>
          <h2 class="section-title-left">Цифровое лицо вашего бизнеса</h2>
          <p class="section-description">
            Мы не используем конструкторы вроде Tilda или Wix. Вы получаете чистый, оптимизированный код, который принадлежит полностью вам.
          </p>
          
          <div class="feature-list">
            {serviceFeatures.map(f => (
              <div class="feature-item">
                <div class="feature-icon-glass">
                  <i class={`fa-solid ${f.icon}`}></i>
                </div>
                <div class="feature-text">
                  <h3>{f.title}</h3>
                  <p>{f.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="visual-content">
           <div class="service-graphic-box-premium">
              <div class="graphic-glow"></div>
              <i class="fa-solid fa-laptop-code graphic-icon-main"></i>
           </div>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <div class="faq-header">
        <h2 class="section-title">Вопросы и ответы</h2>
        <p class="section-subtitle">О процессе разработки сайтов</p>
      </div>
      <div class="faq-container">
        {faqs.map(faq => (
          <details class="faq-item">
            <summary class="faq-question">
              {faq.q}
              <div class="faq-plus"></div>
            </summary>
            <div class="faq-answer">
              <p>{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Contact />
</BaseLayout>

<style>
  .services-info {
    padding: 140px 0;
    background-color: var(--bg-color);
  }

  .section-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent-color);
    margin-bottom: 1rem;
  }

  .section-title-left {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--text-color);
  }

  .section-content-split {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 6rem;
    align-items: center;
  }

  .section-description {
    font-size: 1.15rem;
    color: var(--text-color);
    opacity: 0.85;
    margin-bottom: 4rem;
    line-height: 1.6;
    max-width: 600px;
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .feature-item {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .feature-icon-glass {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(8px);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-color);
    font-size: 1.5rem;
    transition: all 0.3s ease;
  }

  .feature-item:hover .feature-icon-glass {
    background: rgba(var(--accent-color-start-rgb), 0.1);
    border-color: rgba(var(--accent-color-start-rgb), 0.3);
    transform: translateY(-5px);
  }

  .feature-text h3 {
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--text-color);
  }

  .feature-text p {
    color: var(--text-color);
    opacity: 0.75;
    font-size: 1rem;
    line-height: 1.7;
    font-weight: 400;
  }

  .visual-content {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .service-graphic-box-premium {
    width: 100%;
    aspect-ratio: 1;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .graphic-glow {
    position: absolute;
    width: 120%;
    height: 120%;
    background: radial-gradient(circle, rgba(var(--accent-color-start-rgb), 0.1) 0%, transparent 60%);
    z-index: 0;
  }

  .graphic-icon-main {
    font-size: 10rem;
    color: var(--accent-color);
    filter: drop-shadow(0 0 30px rgba(var(--accent-color-start-rgb), 0.3));
    z-index: 1;
  }

  .faq-section {
    padding: 140px 0;
    background-color: var(--primary-color);
  }

  .faq-header {
    margin-bottom: 5rem;
  }

  .faq-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .faq-item {
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    border-radius: 24px;
    margin-bottom: 1.25rem;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-item:hover {
    border-color: rgba(var(--accent-color-start-rgb), 0.4);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .faq-question {
    padding: 2rem;
    font-weight: 700;
    font-size: 1.2rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-color);
    position: relative;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-plus {
    width: 24px;
    height: 24px;
    position: relative;
    transition: transform 0.4s ease;
  }

  .faq-plus::before, .faq-plus::after {
    content: '';
    position: absolute;
    background: var(--accent-color);
    border-radius: 2px;
  }

  .faq-plus::before {
    width: 100%;
    height: 2px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }

  .faq-plus::after {
    width: 2px;
    height: 100%;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
  }

  .faq-item[open] .faq-plus {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 2rem 2.5rem;
    color: var(--text-secondary-color);
    line-height: 1.8;
    font-size: 1.1rem;
  }

  @media (max-width: 1200px) {
    .section-content-split {
      gap: 3rem;
    }
  }

  @media (max-width: 992px) {
    .section-content-split {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .section-title-left {
      text-align: center;
    }
    .section-description {
      margin-left: auto;
      margin-right: auto;
    }
    .feature-item {
      text-align: left;
    }
    .visual-content {
      display: none;
    }
  }
</style>
