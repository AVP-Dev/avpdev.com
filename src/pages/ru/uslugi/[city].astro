---
// src/pages/ru/uslugi/[city].astro
import GeoPageLayout from '../../../layouts/GeoPageLayout.astro';
import { locations } from '../../../data/locations';
import { getCollection } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
    const allGeo = await getCollection('geo');
    return allGeo
        .filter(entry => entry.data.ru || entry.data.en) // Only build if there is SOME content
        .map(entry => ({
            params: { city: entry.id },
            props: { geoEntry: entry },
        }));
}

const { city } = Astro.params;
const { geoEntry } = Astro.props;
const cityData = locations.find(loc => loc.slug === city);
const content = geoEntry.data.ru;

if (!cityData) {
    return new Response(null, { status: 404 });
}

if (!content) {
    if (geoEntry.data.en) {
        return Astro.redirect(`/en/services/${city}/`, 301);
    }
    return new Response(null, { status: 404 });
}

// Fetch relevant projects for THIS city/language to avoid prop-passing bug
const lang = 'ru';
const allProjects = await getCollection('projects', ({ id }) => id.startsWith(lang + '/'));
const projects = allProjects.slice(0, 6);

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "inLanguage": "ru-RU",
  "serviceType": "Веб-разработка",
  "provider": {
    "@type": "Organization",
    "name": "AVPdev.com",
    "url": Astro.site?.toString()
  },
  "areaServed": {
    "@type": "City",
    "name": cityData.name_en
  },
  "name": content.title,
  "description": content.description,
  "url": Astro.url.href
};

const faqSchema = content.faq && content.faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "inLanguage": "ru-RU",
  "mainEntity": content.faq.map((f: any) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.a
    }
  }))
} : null;
---
<GeoPageLayout
    title={content.title}
    description={content.description}
    h1={content.h1}
    p={content.p}
    projects={projects}
    citySlug={city}
    cityName={cityData.name_ru || undefined}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    {faqSchema && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <section class="city-specific-content container fade-in">
    <h2 class="section-title">Почему выбирают AVPdev в {cityData.name_ru}</h2>
    <div class="benefits-grid">
      {content.benefits ? (
        content.benefits.map((b: { icon: string; title: string; desc: string }) => (
          <div class="benefit-item">
            <i class={`fas ${b.icon}`}></i>
            <h3>{b.title}</h3>
            <p>{b.desc}</p>
          </div>
        ))
      ) : (
        <Fragment>
          <div class="benefit-item">
            <i class="fas fa-rocket"></i>
            <h3>Скорость</h3>
            <p>Ваш сайт будет летать, обеспечивая лучший пользовательский опыт в {cityData.name_ru}.</p>
          </div>
          <div class="benefit-item">
            <i class="fas fa-search"></i>
            <h3>SEO-фокус</h3>
            <p>Локальное продвижение специально для рынка {cityData.name_ru}.</p>
          </div>
        </Fragment>
      )}
    </div>
  </section>

  {content.faq && content.faq.length > 0 && (
    <section class="faq-section container fade-in" style="margin-top: 4rem;">
      <h2 class="section-title">Часто задаваемые вопросы</h2>
      <div class="faq-list">
        {content.faq.map((item: { q: string; a: string }) => (
          <details class="faq-item">
            <summary>{item.q}</summary>
            <div class="faq-answer">
               <p>{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </section>
  )}
</GeoPageLayout>

<style>
  .city-specific-content {
    padding: 6rem 0;
    text-align: center;
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
    margin-top: 4rem;
  }
  .benefit-item i {
    font-size: 3rem;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1.5rem;
  }
  .benefit-item h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }
  .faq-section {
    padding-bottom: 6rem;
  }
  .faq-list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .faq-item {
    background: rgba(var(--bg-secondary-rgb, 255, 255, 255), 0.03);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.2rem 1.5rem;
    transition: all 0.3s ease;
  }
  .faq-item:hover {
    border-color: rgba(var(--accent-color-start-rgb), 0.3);
  }
  .faq-item summary {
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    position: relative;
    padding-right: 2rem;
    color: var(--text-color);
    outline: none;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.5rem;
    color: var(--accent-color-start);
  }
  .faq-item[open] summary::after {
    content: '−';
  }
  .faq-answer {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
    color: var(--text-secondary-color);
    font-size: 0.95rem;
    line-height: 1.6;
    animation: fadeIn 0.3s ease-in-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-5px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>