---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/sections/Hero.astro';
import Contact from '../../../components/sections/Contact.astro';

const seoTitle = "Разработка SaaS и MVP для стартапов | AVPdev";
const seoDescription = "Быстрый запуск MVP для стартапов и масштабируемая разработка SaaS платформ на Next.js, Node.js и Astro. От идеи до первых пользователей за 4-8 недель.";

const features = [
  {
    title: "Мощный Backend и API",
    desc: "Разрабатываем надежную микросервисную или монолитную архитектуру (Node.js, Go, Python). Строим REST/GraphQL API для ваших мобильных и веб-приложений.",
    icon: "fa-server"
  },
  {
    title: "Современный Frontend (Next.js)",
    desc: "Создаем реактивные, быстрые и SEO-оптимизированные интерфейсы (React, Vue, Next.js), которые работают мгновенно.",
    icon: "fa-gauge-high"
  },
  {
    title: "Безопасность и DevOps",
    desc: "Настраиваем CI/CD пайплайны, контейнеризацию (Docker, Coolify) и защиту данных ваших пользователей. Ваш сервис выдержит любые нагрузки.",
    icon: "fa-shield-halved"
  }
];

const faqs = [
  {
    q: "Что такое MVP и зачем он нужен?",
    a: "MVP (Minimum Viable Product) — это минимально жизнеспособный продукт. Мы делаем только ключевой функционал, чтобы вы могли запуститься за 1-2 месяца, проверить спрос на рынке и получить первые инвестиции, не тратя годы и огромные бюджеты."
  },
  {
    q: "Подходит ли ваш стек для высоконагруженных SaaS?",
    a: "Абсолютно. Мы используем Next.js (серверный рендеринг) для фронтенда и Node.js с микросервисной архитектурой для бекенда. Это тот же стек, на котором работают Netflix и Uber."
  },
  {
    q: "Можете ли вы взять проект на дальнейшую поддержку?",
    a: "Да, MVP — это только начало. После релиза мы обеспечиваем SLA (соглашение об уровне сервиса), багфиксинг и постепенное наращивание новых фич (Agile/Scrum)."
  },
  {
    q: "Как обеспечивается безопасность данных?",
    a: "Мы используем современные стандарты шифрования, токены доступа (JWT/OAuth), защиту от DDoS, а также настраиваем автоматические регулярные бэкапы баз данных."
  },
  {
    q: "Что входит в этап проектирования архитектуры?",
    a: "Мы проектируем структуру базы данных, описываем логику работы сервисов, выбираем необходимые интеграции и создаем детальную схему взаимодействия (API контракты) еще до написания первой строчки кода."
  },
  {
    q: "Можем ли мы потом нанять свою In-House команду?",
    a: "Конечно. Вы получаете полностью задокументированный и чистый код. Любая квалифицированная команда DevOps и разработчиков сможет легко перенять проект в будущем."
  },
  {
    q: "Интегрируете ли вы платежи по подписке?",
    a: "Да, у нас есть богатый опыт настройки рекуррентных платежей через Stripe, Braintree, ЮKassa и интеграции с системами управления подписками."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Разработка SaaS и MVP",
      "description": seoDescription,
      "provider": {
        "@type": "Person",
        "name": "Алексей Пацкевич"
      },
      "inLanguage": "ru-RU",
      "areaServed": "Worldwide",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "SaaS Услуги",
        "itemListElement": features.map(f => ({
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": f.title,
            "description": f.desc
          }
        }))
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    }
  ]
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  schema={schema}
>
  <Hero 
    title="SaaS & MVP Разработка"
    subtitle="Трансформируем вашу идею в работающий продукт за 4-8 недель. Кодим масштабируемую архитектуру."
    variant="services"
  />

  <section class="services-info">
    <div class="container">
      <div class="section-content-split">
        <div class="text-content">
          <span class="section-label">Development</span>
          <h2 class="section-title-left">От идеи до запуска за 4 недели</h2>
          <p class="section-description">
            Мы помогаем стартапам и бизнесу быстро проверять гипотезы. Создаем масштабируемые MVP, которые не нужно переписывать после роста.
          </p>
          
          <div class="feature-list">
            {features.map(f => (
              <div class="feature-item">
                <div class="feature-icon-glass">
                  <i class={`fa-solid ${f.icon}`}></i>
                </div>
                <div class="feature-text">
                  <h3>{f.title}</h3>
                  <p>{f.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="visual-content">
           <div class="service-graphic-box-premium">
              <div class="graphic-glow"></div>
              <i class="fa-solid fa-rocket graphic-icon-main"></i>
           </div>
        </div>
      </div>
    </div>
  </section>

  

  <section class="faq-section">
    <div class="container">
      <div class="faq-header">
        <h2 class="section-title">Вопросы и ответы</h2>
        <p class="section-subtitle">О запуске новых продуктов</p>
      </div>
      <div class="faq-container">
        {faqs.map(faq => (
          <details class="faq-item">
            <summary class="faq-question">
              {faq.q}
              <div class="faq-plus"></div>
            </summary>
            <div class="faq-answer">
              <p>{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <Contact />
</BaseLayout>

<style>
  .services-info {
    padding: 140px 0;
    background-color: var(--bg-color);
  }

  .section-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent-color);
    margin-bottom: 1rem;
  }

  .section-title-left {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--text-color);
  }

  .section-content-split {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 6rem;
    align-items: center;
  }

  .section-description {
    font-size: 1.15rem;
    color: var(--text-color);
    opacity: 0.85;
    margin-bottom: 4rem;
    line-height: 1.6;
    max-width: 600px;
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .feature-item {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .feature-icon-glass {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(8px);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent-color);
    font-size: 1.5rem;
    transition: all 0.3s ease;
  }

  .feature-item:hover .feature-icon-glass {
    background: rgba(var(--accent-color-start-rgb), 0.1);
    border-color: rgba(var(--accent-color-start-rgb), 0.3);
    transform: translateY(-5px);
  }

  .feature-text h3 {
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--text-color);
  }

  .feature-text p {
    color: var(--text-color);
    opacity: 0.75;
    font-size: 1rem;
    line-height: 1.7;
    font-weight: 400;
  }

  .visual-content {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .service-graphic-box-premium {
    width: 100%;
    aspect-ratio: 1;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .graphic-glow {
    position: absolute;
    width: 120%;
    height: 120%;
    background: radial-gradient(circle, rgba(var(--accent-color-start-rgb), 0.1) 0%, transparent 60%);
    z-index: 0;
  }

  .graphic-icon-main {
    font-size: 10rem;
    color: var(--accent-color);
    filter: drop-shadow(0 0 30px rgba(var(--accent-color-start-rgb), 0.3));
    z-index: 1;
  }

  .faq-section {
    padding: 140px 0;
    background-color: var(--primary-color);
  }

  .faq-header {
    margin-bottom: 5rem;
  }

  .faq-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .faq-item {
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    border-radius: 24px;
    margin-bottom: 1.25rem;
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faq-item:hover {
    border-color: rgba(var(--accent-color-start-rgb), 0.4);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .faq-question {
    padding: 2rem;
    font-weight: 700;
    font-size: 1.2rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-color);
    position: relative;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-plus {
    width: 24px;
    height: 24px;
    position: relative;
    transition: transform 0.4s ease;
  }

  .faq-plus::before, .faq-plus::after {
    content: '';
    position: absolute;
    background: var(--accent-color);
    border-radius: 2px;
  }

  .faq-plus::before {
    width: 100%;
    height: 2px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }

  .faq-plus::after {
    width: 2px;
    height: 100%;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
  }

  .faq-item[open] .faq-plus {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 2rem 2.5rem;
    color: var(--text-secondary-color);
    line-height: 1.8;
    font-size: 1.1rem;
  }

  @media (max-width: 1200px) {
    .section-content-split {
      gap: 3rem;
    }
  }

  @media (max-width: 992px) {
    .section-content-split {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .section-title-left {
      text-align: center;
    }
    .section-description {
      margin-left: auto;
      margin-right: auto;
    }
    .feature-item {
      text-align: left;
    }
    .visual-content {
      display: none;
    }
  }
</style>
