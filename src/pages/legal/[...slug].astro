---
// src/pages/legal/[...slug].astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

export async function getStaticPaths() {
	const legalPages = await getCollection('legal');
	return legalPages.map(page => ({
		params: { slug: page.slug },
		props: page,
	}));
}

const { data, render } = Astro.props;
const { Content } = await render();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<BaseLayout title={data.title} description={data.description}>
    <main class="legal-page-content">
        <div class="container legal-container">
            <Content />
            <a href={`/${lang}/`} class="back-to-main" set:html={t('back_to_home')}></a>
        </div>
    </main>
</BaseLayout>

<style is:global>
    .legal-page-content {
        padding-top: 120px;
        padding-bottom: 80px;
    }
    .legal-container {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem;
        background-color: var(--primary-color);
        border-radius: 15px;
        border: var(--glass-border);
    }
    .legal-container h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
    .legal-container h3 { font-size: 1.8rem; margin-top: 2.5rem; margin-bottom: 1rem; }
    .legal-container p, .legal-container ul { line-height: 1.8; color: var(--text-secondary-color); margin-bottom: 1rem; }
    .legal-container ul { padding-left: 20px; }
    .legal-container a { color: var(--accent-color-start); }
    .legal-container .last-updated { margin-bottom: 2rem; }
</style>